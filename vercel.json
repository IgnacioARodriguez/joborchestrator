{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix dashboard ci",
  "buildCommand": "npm --prefix dashboard run build",
  "framework": "nextjs",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
