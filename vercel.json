{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd dashboard && npm ci",
  "buildCommand": "cd dashboard && npm run build",
  "outputDirectory": "dashboard/.next",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
