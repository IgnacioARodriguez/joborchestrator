# Copy this file to .env and fill the values.
# .env is ignored by Git and is loaded automatically by the local Python API,
# local worker, and maintenance scripts.

# Remote durable storage used by Vercel/v0 and the local worker.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# LLM keys used for CV import, ranking and generated materials.
NVIDIA_API_KEY=nvapi-your-key
OPENAI_API_KEY=

# Optional model overrides. Leave empty to use app defaults.
NVIDIA_BASE_URL=
NVIDIA_MODEL=
NVIDIA_RANKING_MODEL=
PROFILE_EXTRACTION_MODEL=
OPENAI_MODEL=
OPENAI_RANKING_MODEL=
OPENAI_MATERIALS_MODEL=

# Optional local database path when Turso is not configured.
JOB_ORCHESTRATOR_DB_PATH=

# Optional worker tuning.
JOB_WORKER_POLL_SECONDS=5
RANKING_WORKER_POLL_SECONDS=5
RANKING_WORKER_CHUNK_SIZE=25
NVIDIA_RANKING_BATCH_SIZE=5
NVIDIA_RANKING_MAX_CONCURRENCY=2
NVIDIA_RANKING_MAX_TOKENS=8192
